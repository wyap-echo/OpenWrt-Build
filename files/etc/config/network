
config interface 'loopback'
	option device 'lo'
	option proto 'static'
	option ipaddr '127.0.0.1'
	option netmask '255.0.0.0'

config globals 'globals'
	option ula_prefix 'fdd2:348f:6b49::/48'

config device
	option name 'br-lan'
	option type 'bridge'
	list ports 'eth0'

config device
	option name 'eth0'
	option macaddr 'b8:60:61:74:14:a4'

config interface 'lan'
	option device 'br-lan'
	option proto 'static'
	option ipaddr '192.168.2.1'
	option netmask '255.255.255.0'
	option ip6assign '64'
	option delegate '0'
	option ip6ifaceid 'eui64'

config device
	option name 'eth1'
	option macaddr 'b8:60:61:74:14:a1'

config interface 'wan'
	option device 'eth1'
	option proto 'pppoe'
	option username 'PPPOE_USER'
	option password 'PPPOE_PASS'
	option mtu '1492'
	option ipv6 'auto'

config switch
	option name 'switch0'
	option reset '1'
	option enable_vlan '1'

config switch_vlan
	option device 'switch0'
	option vlan '1'
	option ports '0 1 2 6'

config interface 'Modem'
	option proto 'static'
	option device 'eth1'
	option ipaddr '192.168.1.2'
	option netmask '255.255.255.0'

